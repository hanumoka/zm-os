{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npm ls *)",
      "Bash(npx tsc *)",
      "Bash(npx next *)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(PYTHONUTF8=1 python *)",
      "Skill(zm-memory-save)",
      "Skill(zm-session)",
      "Skill(zm-work-intake)",
      "Skill(zm-work-completion)",
      "Skill(zm-commit)",
      "Skill(zm-unit-done)",
      "Skill(zm-troubleshoot)",
      "Skill(zm-doc-status)",
      "Skill(zm-roadmap)",
      "Skill(zm-wu-start)",
      "Skill(zm-wu-stop)",
      "Skill(zm-wu-next)",
      "Skill(zm-handoff)",
      "Skill(zm-setup)",
      "Skill(zm-team)",
      "Skill(zm-onboarding)",
      "Skill(zm-agent-teams)",
      "Bash(python -X utf8 .claude/hooks/wu_claim_manager.py *)",
      "Bash(python -X utf8 scripts/setup-git-hooks.py)",
      "Bash(python -X utf8 scripts/derive-wu-state.py)",
      "Bash(bash scripts/install-merge-drivers.sh)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/mistake_guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/mistake_guard_edit.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/category_guard.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/post_review.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/post_review_checks.py\"",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/emit_event.py\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wu_claim_manager.py\" touch",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_start.py\"",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/prompt_context.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_compact.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/post_compact.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/notify_done.py\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wu_claim_manager.py\" mark-stopped",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "head",
    "cleanupPeriodDays": 1
  }
}
