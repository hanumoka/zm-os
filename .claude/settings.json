{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npm ls *)",
      "Bash(npx tsc *)",
      "Bash(npx next *)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(PYTHONUTF8=1 python *)",
      "Skill(zm-memory-save)",
      "Skill(zm-session)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/mistake_guard.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/post_review.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_start.py\"",
            "timeout": 8
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/notify_done.py\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
