{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@zm/core": ["../../packages/core/src"],
      "@zm/core/*": ["../../packages/core/src/*"],
      "@zm/storage": ["../../packages/storage/src"],
      "@zm/storage/*": ["../../packages/storage/src/*"],
      "@zm/ipc": ["../../packages/ipc/src"],
      "@zm/ipc/*": ["../../packages/ipc/src/*"],
      "@zm/adapters-local": ["../../packages/adapters-local/src"],
      "@zm/adapters-local/*": ["../../packages/adapters-local/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
